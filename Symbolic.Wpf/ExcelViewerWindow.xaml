<Window x:Class="Calcpad.Wpf.ExcelViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Calcpad — Visor Excel (Univer)"
        Height="800" Width="1280"
        WindowStartupLocation="CenterScreen"
        Icon="Resources/calcpad.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBar Grid.Row="0">
            <Button x:Name="OpenBtn" Click="OpenBtn_Click" Padding="8,4" Margin="2">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📂 Abrir .xlsx" FontSize="13"/>
                </StackPanel>
            </Button>
            <Button x:Name="SaveBtn" Click="SaveBtn_Click" Padding="8,4" Margin="2" IsEnabled="False">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="💾 Guardar .xlsx" FontSize="13"/>
                </StackPanel>
            </Button>
            <Separator/>
            <TextBlock x:Name="FileNameLabel" Text="(ningún archivo)" Margin="8,0" VerticalAlignment="Center" Foreground="#555"/>
        </ToolBar>

        <Wpf:WebView2 Grid.Row="1" x:Name="Viewer"
                      NavigationCompleted="Viewer_NavigationCompleted"
                      WebMessageReceived="Viewer_WebMessageReceived"/>

        <StatusBar Grid.Row="2">
            <TextBlock x:Name="StatusLabel" Text="Listo" Margin="4,0"/>
        </StatusBar>
    </Grid>
</Window>
