<UserControl x:Class="Calcpad.Wpf.MathEditor.MathCanvasControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="True"
             FocusVisualStyle="{x:Null}"
             Background="White"
             PreviewMouseDown="UserControl_PreviewMouseDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header bar -->
        <Border Grid.Row="0" Background="#F5F5DC" BorderBrush="#CCC" BorderThickness="1,1,1,0" Padding="5,3">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="MathCanvas" FontSize="10" Foreground="#666" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Border Background="#E3F2FD" BorderBrush="#1976D2" BorderThickness="1"
                        CornerRadius="3" Padding="6,2" Margin="0,0,10,0">
                    <TextBlock x:Name="StatusText" Text="Listo" FontSize="9" Foreground="#1976D2"/>
                </Border>
                <!-- Zoom controls -->
                <Button Content="−" Width="22" Height="22" FontSize="12" Click="ZoomOut_Click"
                        ToolTip="Zoom Out" Margin="0,0,2,0" Focusable="False"/>
                <TextBlock x:Name="ZoomLabel" Text="100%" FontSize="9" VerticalAlignment="Center"
                           Foreground="#666" Margin="2,0,2,0"/>
                <Button Content="+" Width="22" Height="22" FontSize="12" Click="ZoomIn_Click"
                        ToolTip="Zoom In" Focusable="False"/>
            </StackPanel>
        </Border>

        <!-- Main canvas area with scroll -->
        <ScrollViewer x:Name="MainScroll" Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Focusable="False"
                      Background="White"
                      HorizontalContentAlignment="Left"
                      VerticalContentAlignment="Top">
            <Canvas x:Name="EditorCanvas"
                    x:FieldModifier="public"
                    AutomationProperties.AutomationId="EditorCanvas"
                    Background="White"
                    Focusable="True"
                    FocusVisualStyle="{x:Null}"
                    ClipToBounds="True"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"/>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#CCC" BorderThickness="1,1,1,0" Padding="5,2">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LineInfo" Text="Ln 1" FontSize="9" Foreground="#888"
                           VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock x:Name="ParseInfo" Text="" FontSize="9" Foreground="#888"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
